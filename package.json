{
  "name": "win-agent",
  "version": "0.1.0",
  "description": "Multi-agent workflow engine powered by opencode SDK",
  "type": "module",
  "bin": {
    "win-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@inquirer/prompts": "^7.3.2",
    "@opencode-ai/sdk": "^1.3.13",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node"
    ]
  }
}
