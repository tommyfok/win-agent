{
  "name": "win-agent",
  "version": "0.1.0",
  "description": "Multi-agent workflow engine powered by opencode SDK",
  "type": "module",
  "bin": {
    "win-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit && eslint src",
    "lint:fix": "tsc --noEmit && eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "inspect:sessions": "tsx scripts/inspect-opencode-sessions.ts",
    "test": "vitest run",
    "deploy:local": "pnpm lint && pnpm test && pnpm build && npm link"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@inquirer/prompts": "^7.3.2",
    "@opencode-ai/sdk": "^1.3.13",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "lru-cache": "^11.0.2",
    "pino": "^10.3.1",
    "sqlite-vec": "^0.1.9",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.4.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
